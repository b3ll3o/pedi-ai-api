// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senha         String
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  version       Int            @default(1)
  perfilId      String?        @map("perfil_id")
  perfil        Perfil?        @relation(fields: [perfilId], references: [id])
  refreshTokens RefreshToken[] @relation("UserRefreshTokens")

  // Índices:
  // - deletedAt: todo findBy/findAll filtra `deletedAt: null`. Sem índice,
  //   Postgres faz seq scan. Em produção com 100k users isso vira o gargalo
  //   dominante das requests autenticadas.
  // - perfilId: FK sem índice faz o `include: { perfil }` virar nested-loop
  //   seq scan em profiles quando o filtro de users não é seletivo.
  @@index([deletedAt])
  @@index([perfilId])
  @@map("users")
}

model Perfil {
  id         String      @id @default(uuid())
  nome       String      @unique
  descricao  String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")
  version    Int         @default(1)
  permissoes Permissao[]
  usuarios   User[]

  @@map("perfis")
}

model Permissao {
  id        String    @id @default(uuid())
  nome      String    @unique
  chave     String    @unique
  descricao String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  version   Int       @default(1)
  perfis    Perfil[]

  @@map("permissoes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation("UserRefreshTokens", fields: [userId], references: [id])
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // expiresAt: cleanup job roda `deleteMany({ where: { expiresAt: { lt: now } } })`
  // periodicamente (e em `validateRefreshToken` via path). Sem índice é seq scan
  // em uma tabela que cresce indefinidamente até alguém podá-la.
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Restaurante {
  id               String    @id @default(uuid())
  nome             String
  cnpj             String    @unique
  email            String?
  telefone         String?
  endereco         String
  cidade           String
  estado           String    @db.VarChar(2)
  cep              String
  horarioAbertura  String    @db.VarChar(5)
  horarioFechamento String   @db.VarChar(5)
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  version          Int       @default(1)

  // deletedAt: idem User — todas as listagens filtram soft-delete. cidade
  // também é candidato futuro (queries "restaurantes em SP" são esperadas
  // no app), mas ainda não há query concreta, então deixo só deletedAt.
  @@index([deletedAt])
  @@map("restaurantes")
}

/// Tokens JWT (identificados pelo `jti`) revogados por logout. Ao validar
/// um access token, o JwtAuthGuard consulta esta tabela: se o jti existir
/// com `expiresAt > now`, o token é considerado inválido.
///
/// Substitui o antigo `TokenBlacklistService` em memória, que era por-instância
/// e quebrava em deploy multi-instância (revogação em uma instância não era
/// visível em outras). Persistir no Postgres garante consistência.
///
/// `expiresAt`: cleanup periódico remove linhas com `expiresAt < now` — sem
/// índice a tabela cresce indefinidamente. O índice também é usado pelo
/// `findFirst({ where: { jti, expiresAt: { gt: now } } })` no `isRevoked`.
model RevokedJti {
  jti       String   @id
  userId    String?  @map("user_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime @default(now()) @map("revoked_at")

  @@index([expiresAt])
  @@map("revoked_jtis")
}
