# Server
PORT=3001

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# JWT Configuration (OBRIGATÓRIO em produção)
JWT_SECRET="sua-chave-secreta-jwt-minimo-256-bits"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS (OBRIGATÓRIO em produção)
# Lista de origens separadas por vírgula
ALLOWED_ORIGINS="http://localhost:3000,https://seu-dominio.com"

# Throttler (rate limit) — limites de requests por janela de tempo.
# Janela curta: 60s, janela longa: 1h. Aumente em ambientes de teste/CI
# para evitar 429 nos testes paralelos; em produção mantenha os defaults.
THROTTLE_SHORT_LIMIT=5
THROTTLE_LONG_LIMIT=30
